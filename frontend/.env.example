# RADAR frontend — configuración opcional. Sin nada de esto, la app funciona
# en modo ESTÁTICO: carga /products.json (el snapshot que genera el backend).

# Modo estático: de dónde cargar el snapshot (por defecto, /products.json del
# propio hosting). Útil si sirves el JSON desde otra URL/CDN.
# VITE_DATA_URL=https://tu-cdn.com/products.json

# Modo API en vivo: si defines esto, la app consulta el backend Hono en vivo
# (/search + /facets) en lugar del snapshot estático. Para desarrollo local:
# VITE_API_URL=http://localhost:3000
